{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nes-emulator",
  "version": "../../../package.json",
  "identifier": "com.wandergame.nesemulator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5181",
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "NES/FC 模拟器",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEN0M3NkIyM0MwRUFEQzYKUldUR3JRNDhzblo4alZ4dVRCUHJzekJPUUgwUG9SaVdJT2hDcytnQStBdkY2UkxhN1FhMUxvN1AK",
      "endpoints": [
        "https://github.com/while-coder/nes-emulator/releases/download/updater/latest.json"
      ]
    }
  }
}
